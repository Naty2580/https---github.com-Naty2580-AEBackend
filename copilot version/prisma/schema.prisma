generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= ENUMS =================

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  CUSTOMER
  DELIVERER
  VENDOR_STAFF
  ADMIN
}

enum ActiveMode {
  CUSTOMER
  DELIVERER
}

enum MfaMethod {
  TOTP
  SMS
  EMAIL
}

// ================= MODELS =================

model User {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegramId      BigInt     @unique
  astuEmail       String     @unique
  fullName        String
  phoneNumber     String     @unique
  password        String
  role            UserRole   @default(CUSTOMER)
  activeMode      ActiveMode @default(CUSTOMER)
  isEmailVerified Boolean    @default(false)
  failedAttempts  Int        @default(0)
  lockoutUntil    DateTime?
  lastLoginAt     DateTime?
  deviceToken     String?
  mfaEnabled      Boolean    @default(false)
  mfaSecret       String?
  mfaMethod       MfaMethod  @default(TOTP)
  passwordResetToken String?
  passwordResetExpires DateTime?
  trustedDevices  TrustedDevice[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Profiles
  customerProfile  CustomerProfile?
  delivererProfile DelivererProfile?
  vendorProfile    VendorProfile?

  // System Relations
  refreshTokens RefreshToken[]
  statusChanges    OrderStatusHistory[]
  notifications    Notification[]
  ratingsGiven     Rating[]      @relation("RatingsGiven")
  ratingsReceived  Rating[]      @relation("RatingsReceived")
  ledgerEntries    LedgerEntry[]
  disputesRaised   Dispute[]     @relation("DisputesRaised")
  disputesAssigned Dispute[]     @relation("DisputesAssigned")
  dispatchLogs     DispatchLog[]
  authLogs         AuthLog[]

  @@index([astuEmail])
  @@index([telegramId])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model CustomerProfile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating          Decimal  @default(5.0) @db.Decimal(3, 2)
  totalOrders     Int      @default(0)
  preferredPaymentMethod String?

  // Relations
  orders           Order[]

  @@index([rating])
  @@index([totalOrders])
}

model DelivererProfile {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String             @unique @db.Uuid
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  isVerified         Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  isOnline           Boolean            @default(false)
  rating             Decimal            @default(5.0) @db.Decimal(3, 2)
  isAvailable        Boolean            @default(false)
  payoutAccount      String?
  payoutProvider     String?
  totalDeliveries    Int                @default(0)
  totalEarnings      Decimal            @default(0.00) @db.Decimal(10, 2)
  currentLocation    Unsupported("geometry(Point, 4326)")?
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  mode      String     @default("VENDOR_MANAGED")
  lat       Float
  lng       Float
  isOpen    Boolean    @default(false)
  imageUrl  String?
  contactPhone String?
  operatingHours Json?

  // Relations
  staff      VendorProfile[]
  categories Category[]
  menu       MenuItem[]
  orders     Order[]

  @@index([lat, lng])
  @@index([isOpen])
}

model VendorProfile {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String     @unique @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  isOwner      Boolean    @default(false)

  @@index([restaurantId])
}

model Category {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(0)

  // Relations
  products     MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String     @db.Uuid
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  imageUrl     String?
  isAvailable  Boolean    @default(true)
  prepTimeMins Int        @default(15)

  // Relations
  orderItems   OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([price])
  @@index([isAvailable])
  @@index([prepTimeMins])
}

model Order {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shortId        String        @unique
  customerId     String        @db.Uuid
  delivererId    String?       @db.Uuid
  restaurantId   String        @db.Uuid

  // Financials
  foodPrice      Decimal       @db.Decimal(10, 2)
  deliveryFee    Decimal       @db.Decimal(10, 2)
  transactionFee Decimal       @default(0.00) @db.Decimal(10, 2)
  serviceFee     Decimal       @db.Decimal(10, 2)
  tip            Decimal       @default(0.00) @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)

  // State
  status         String        @default("CREATED")
  paymentStatus  String        @default("AWAITING_PAYMENT")
  otpCode        String        @unique
  otpVerifiedAt  DateTime?
  chapaRef       String?       @unique
  payoutRef      String?       @unique

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  customer       CustomerProfile   @relation(fields: [customerId], references: [id])
  deliverer      DelivererProfile? @relation(fields: [delivererId], references: [id])
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id])

  items          OrderItem[]
  payments       Payment[]
  ratings        Rating[]
  statusHistory  OrderStatusHistory[]
  ledgerEntries  LedgerEntry[]
  disputes       Dispute[]
  dispatchLogs   DispatchLog[]

  @@index([status])
  @@index([customerId])
  @@index([restaurantId])
  @@index([delivererId])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId    String   @db.Uuid
  product   MenuItem @relation(fields: [menuId], references: [id])
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
}

model OrderStatusHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  oldStatus String?
  newStatus String
  changedById String @db.Uuid
  user      User     @relation(fields: [changedById], references: [id])
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([changedById])
}

model Payment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @unique @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactionId String?  @unique
  provider    String?
  status      String  @default("AWAITING_PAYMENT")
  amount    Decimal  @db.Decimal(10, 2)
  deliveryFee Decimal  @db.Decimal(10, 2)
  serviceFee Decimal  @db.Decimal(10, 2)
  tip        Decimal  @db.Decimal(10, 2)
  payoutAmount Decimal  @db.Decimal(10, 2)
  attempts    Int      @default(1)
  createdAt DateTime @default(now())
}

model Rating {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  raterId    String   @db.Uuid
  user      User     @relation("RatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  rateeId    String   @db.Uuid
  ratedUser User     @relation("RatingsReceived", fields: [rateeId], references: [id], onDelete: Cascade)
  orderId   String   @unique @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  sentAt   DateTime @default(now())
  delivered Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model LedgerEntry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @db.Uuid
  userId    String?  @db.Uuid
  amount    Decimal  @db.Decimal(10, 2)
  type      String
  status    String   @default("PENDING")
  reference String?  @unique
  createdAt DateTime @default(now())

  // Relations
  order     Order @relation(fields: [orderId], references: [id])
  user      User? @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([type, status])
}

model Dispute {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String   @db.Uuid
  raisedById      String   @db.Uuid
  assignedAdminId String?
  reason          String   @db.Text
  status          String   @default("OPEN")
  resolution      String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  order         Order @relation(fields: [orderId], references: [id])
  raisedBy      User  @relation("DisputesRaised", fields: [raisedById], references: [id])
  assignedAdmin User? @relation("DisputesAssigned", fields: [assignedAdminId], references: [id])

  @@index([status])
  @@index([orderId])
}

model DispatchLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @db.Uuid
  delivererId String   @db.Uuid
  action      String
  createdAt   DateTime @default(now())

  // Relations
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliverer User  @relation(fields: [delivererId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([delivererId])
}

model TrustedDevice {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  deviceId  String   // Unique device identifier
  deviceName String?
  ipAddress String?
  userAgent String?
  lastUsed  DateTime @default(now())
  isActive  Boolean  @default(true)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

model AuthLog {

model AuthLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @db.Uuid
  action    String   // 'login', 'logout', 'failed_login', 'password_change', etc.
  ipAddress String?
  userAgent String?
  success   Boolean  @default(true)
  details   Json?    // Additional context
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}