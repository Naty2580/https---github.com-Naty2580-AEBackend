generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================= ENUMS =================

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum UserRole {
  CUSTOMER
  DELIVERER
  VENDOR_STAFF
  ADMIN
}

enum ActiveMode {
  CUSTOMER
  DELIVERER
}

enum VendorMode {
  VENDOR_MANAGED
  ADMIN_MANAGED
}

enum OrderStatus {
  CREATED
  AWAITING_ACCEPT
  ASSIGNED
  AWAITING_PAYMENT
  PAYMENT_RECEIVED
  VENDOR_BEING_PREPARED
  VENDOR_FINISHED
  VENDOR_READY_FOR_PICKUP
  PICKED_UP
  EN_ROUTE
  ARRIVED
  RECEIVED
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
  NO_DELIVERER_FOUND
}

enum PaymentStatus {
  AWAITING_PAYMENT
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum LedgerTransactionType {
  ESCROW_RESERVE
  REIMBURSEMENT_PAYMENT
  PLATFORM_REVENUE
  REFUND
  DISPUTE_HOLD
}

enum LedgerEntryStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum DispatchAction {
  BROADCAST
  ACCEPTED
  DECLINED
  IGNORED
}

// ================= MODELS =================

model User {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegramId      BigInt     @unique
  astuEmail       String     @unique
  fullName        String
  phoneNumber     String     @unique
  password        String 
  gender          String?  
  avatarUrl       String?
  status          String     @default("ACTIVE") // 'ACTIVE', 'BANNED', 'PENDING' 
  isEmailVerified Boolean    @default(false)
  role            UserRole   @default(CUSTOMER)
  activeMode      ActiveMode @default(CUSTOMER)
  lastActiveAt     DateTime   @default(now())
  deviceToken      String?    // For push notifications
   failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Profiles
  customerProfile  CustomerProfile?
  delivererProfile DelivererProfile?
  vendorProfile    VendorProfile?

  // System Relations (Root User level)
  refreshTokens RefreshToken[]
  verificationTokens VerificationToken[]
  statusChanges    OrderStatusHistory[]
  notifications    Notification[]
  auditLogs       UserAuditLog[] @relation("UserAudited")
  performedAudits UserAuditLog[] @relation("UserAuditor")
  ratingsGiven     Rating[]      @relation("RatingsGiven")
  ratingsReceived  Rating[]      @relation("RatingsReceived")
  ledgerEntries    LedgerEntry[]
  disputesRaised   Dispute[]     @relation("DisputesRaised")
  disputesAssigned Dispute[]     @relation("DisputesAssigned")
  dispatchLogs     DispatchLog[]

  @@index([astuEmail])
  @@index([telegramId])
  @@index([role, status])
}


model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ADD this model to schema.prisma
model VerificationToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique // Store hashed OTP/Token, never plain text
  type      TokenType
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model UserAuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetUserId String   @db.Uuid
  actorId     String   @db.Uuid
  action      String   // e.g., "ROLE_CHANGE", "STATUS_CHANGE", "DELIVERER_REVIEW"
  previousValue String?
  newValue    String?
  reason      String?
  createdAt   DateTime @default(now())

  targetUser  User     @relation("UserAudited", fields: [targetUserId], references: [id])
  actor       User     @relation("UserAuditor", fields: [actorId], references: [id])

  @@index([targetUserId])
  @@index([actorId])
}


model CustomerProfile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultLocation String?
  rating          Decimal  @default(5.0) @db.Decimal(3, 2)
  totalOrders     Int      @default(0)
  prefferedPaymentMethod String? // e.g., 'CBE', 'Telebirr'
  bookmarkRestaurants String[] // List of restaurant IDs
  bookmarkMeals String[] // List of meal IDs
   

  
  // Relations
  orders           Order[]

  @@index([defaultLocation])
  @@index([rating])
  @@index([totalOrders])
}

model DelivererProfile {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String             @unique @db.Uuid
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  isVerified         Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  isOnline           Boolean            @default(false)
  currentLocation    String?            // Nullable when offline
  rating             Decimal            @default(5.0) @db.Decimal(3, 2)
  isAvailable        Boolean            @default(false)
  payoutAccount      String?            // Nullable until verified
  payoutProvider     String?            // telebirr, cbe
  totalDeliveries    Int                @default(0)
  totalEarnings      Decimal            @default(0.00) @db.Decimal(10, 2)
  
  // Relations
  deliveries         Order[]

  @@index([isVerified])
  @@index([userId,isOnline])
  @@index([rating])
  @@index([isAvailable])
  @@index([totalDeliveries])
  @@index([totalEarnings])
}

model Restaurant {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  phone     String
  // ownerId   String     @unique @db.Uuid
  // owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  mode      VendorMode @default(VENDOR_MANAGED) // Added from PRD
  location  String
  lat       Float
  lng       Float
  isOpen    Boolean    @default(false)
  operatingHours String?    // e.g., "Mon-Fri 9am-9pm; Sat-Sun 10am-8pm"
  imageUrl  String?
  
  // Relations
  staff      VendorProfile[]
  categories Category[]
  menu       MenuItem[]
  orders     Order[]

  @@index([lat, lng])
  @@index([isOpen])
}

model VendorProfile {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String     @unique @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  isOwner      Boolean    @default(false)

  @@index([restaurantId])

}

model Category {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(0)
  
  // Relations
  products     MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String     @db.Uuid
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  imageUrl     String?
  isAvailable  Boolean    @default(true)
  prepTimeMins Int        @default(15)
  
  // Relations
  orderItems   OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([price])
  @@index([isAvailable])
  @@index([prepTimeMins])
}

model Order {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shortId        String        @unique // e.g., AE-1024
  customerId     String        @db.Uuid
  delivererId    String?       @db.Uuid
  restaurantId   String        @db.Uuid
  estimatedDeliveryTime DateTime?
  
  // Financials
  foodPrice      Decimal       @db.Decimal(10, 2)
  deliveryFee    Decimal       @db.Decimal(10, 2)
  transactionFee Decimal       @default(0.00) @db.Decimal(10, 2)
  serviceFee     Decimal       @db.Decimal(10, 2)
  tip            Decimal       @default(0.00) @db.Decimal(10, 2) // Added from PRD
  totalAmount    Decimal       @db.Decimal(10, 2)
  
  // State
  status         OrderStatus   @default(CREATED)
  paymentStatus  PaymentStatus @default(AWAITING_PAYMENT)
  otpCode        String        @unique
  otpVerifiedAt  DateTime?
  chapaRef       String?       @unique
  
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  customer       CustomerProfile   @relation(fields: [customerId], references: [id])
  deliverer      DelivererProfile? @relation(fields: [delivererId], references: [id])
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id])
  
  items          OrderItem[]
  payments       Payment[]
  ratings        Rating[]
  statusHistory  OrderStatusHistory[]
  ledgerEntries  LedgerEntry[]
  disputes       Dispute[]
  dispatchLogs   DispatchLog[]

  @@index([status])
  @@index([customerId])
  @@index([restaurantId])
  @@index([delivererId])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId    String   @db.Uuid
  product   MenuItem @relation(fields: [menuId], references: [id])
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2) // Price captured at time of order
}

model OrderStatusHistory {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String       @db.Uuid
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  oldStatus OrderStatus?
  newStatus OrderStatus
  changedById String     @db.Uuid
  user      User         @relation(fields: [changedById], references: [id])
  createdAt DateTime     @default(now())

  @@index([orderId])
  @@index([changedById])
}

model Payment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @unique @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactionId String?  @unique
  provider    String?  // telebirr, cbe
  status      PaymentStatus @default(AWAITING_PAYMENT)   
  apiResponse String?  @db.Text
  amount    Decimal  @db.Decimal(10, 2)
  deliveryFee Decimal  @db.Decimal(10, 2)
  serviceFee Decimal  @db.Decimal(10, 2)
  tip        Decimal  @db.Decimal(10, 2)
  refundReason String?  @db.Text
  webhookReceivedAt DateTime?
  payoutAmount Decimal  @db.Decimal(10, 2)
  attempts    Int      @default(1)
  createdAt DateTime @default(now())
}


model Rating {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  raterId    String   @db.Uuid
  user      User     @relation("RatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  rateeId    String   @db.Uuid
  ratedUser User     @relation("RatingsReceived", fields: [rateeId], references: [id], onDelete: Cascade)
  orderId   String   @unique @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  sentAt   DateTime @default(now())
  delivered Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model LedgerEntry {
  id        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String                @db.Uuid
  userId    String?               @db.Uuid // Nullable: Revenue belongs to system
  amount    Decimal               @db.Decimal(10, 2)
  type      LedgerTransactionType
  status    LedgerEntryStatus     @default(PENDING)
  description String?               @db.Text
  reference String?               @unique
  createdAt DateTime              @default(now())

  // Relations
  order     Order @relation(fields: [orderId], references: [id])
  user      User? @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([type, status])
}

model Dispute {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String        @db.Uuid
  raisedById      String        @db.Uuid
  assignedAdminId String?       @db.Uuid
  reason          String        @db.Text
  evidence       String?       @db.Text
  status          DisputeStatus @default(OPEN)
  resolution      String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  order         Order @relation(fields: [orderId], references: [id])
  raisedBy      User  @relation("DisputesRaised", fields: [raisedById], references: [id])
  assignedAdmin User? @relation("DisputesAssigned", fields: [assignedAdminId], references: [id])

  @@index([status])
  @@index([orderId])
}

model DispatchLog {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String         @db.Uuid
  delivererId String         @db.Uuid
  action      DispatchAction
  createdAt   DateTime       @default(now())

  // Relations
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliverer User  @relation(fields: [delivererId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([delivererId])
}

model SystemConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

